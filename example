</style> <script src="https://code.jquery.com/jquery-3.6.0.min.js"></script> <script>
  $(document).ready(function() {
    var audioElement = document.getElementById("bg-sound");
    var fadeTime = 300; // Время затухания в миллисекундах (0.3 секунды)
    var isPlaying = localStorage.getItem('audioPlaying');
    var interactionCount = 0; // Счётчик взаимодействий
    var isStoppedManually = false; // Флаг ручной остановки
    audioElement.volume = 0.4; // Громкость
    $(".stopbgmusic").hide();

    function playAudio() {
      if (audioElement.paused) {
        audioElement.muted = false; // Снимаем muted
        var playPromise = audioElement.play();
        if (playPromise !== undefined) {
          playPromise
            .then(function() {
              // Воспроизведение успешно началось
              localStorage.setItem('audioPlaying', 'true');
              $(".playbgmusic").fadeOut(fadeTime);
              $(".stopbgmusic").fadeIn(fadeTime);
              interactionCount = 0; // Сбрасываем счётчик
              isStoppedManually = false; // Сбрасываем флаг
            })
            .catch(function(error) {
              console.log('Ошибка воспроизведения:', error);
              // Если воспроизведение не удалось, восстанавливаем кнопку Play
              $(".stopbgmusic").fadeOut(fadeTime);
              $(".playbgmusic").fadeIn(fadeTime);
            });
        }
      }
    }

    function stopAudio() {
      audioElement.pause();
      localStorage.removeItem('audioPlaying');
      $(".stopbgmusic").fadeOut(fadeTime);
      $(".playbgmusic").fadeIn(fadeTime);
      interactionCount = 0; // Сбрасываем счётчик
      isStoppedManually = true; // Устанавливаем флаг ручной остановки
    }

    // Функция обработки взаимодействий
    function handleInteraction() {
      if (audioElement.paused) {
        if (isStoppedManually) {
          interactionCount++; // Увеличиваем счётчик после паузы
          if (interactionCount >= 2) {
            playAudio(); // Запускаем после второго взаимодействия
          }
        } else {
          playAudio(); // Запускаем с первого взаимодействия до паузы
        }
      }
    }

    // Проверка автозапуска при загрузке
    if (isPlaying === 'true') {
      var testPlay = audioElement.play();
      if (testPlay !== undefined) {
        testPlay
          .then(function() {
            // Автозапуск успешен
            playAudio();
          })
          .catch(function(error) {
            console.log('Автозапуск заблокирован:', error);
            // Если автозапуск не удался, оставляем кнопку Play видимой
            $(".stopbgmusic").hide();
            $(".playbgmusic").show();
          });
      }
    }

    // Обработчики для взаимодействий
    window.addEventListener('scroll', function() {
      handleInteraction();
    });

    document.addEventListener('click', function() {
      handleInteraction();
    });

    document.addEventListener('touchstart', function() {
      handleInteraction();
    });

    // Остановка при закрытии страницы
    window.addEventListener('beforeunload', function() {
      stopAudio();
    });

    // Обработчики для ваших кнопок
    $(".playbgmusic").click(function(e) {
      e.preventDefault();
      interactionCount = 0; // Сбрасываем счётчик
      isStoppedManually = false; // Сбрасываем флаг
      playAudio();
    });

    $(".stopbgmusic").click(function(e) {
      e.preventDefault();
      stopAudio();
    });

    // Обработка окончания воспроизведения
    $("#bg-sound").on("ended", function() {
      stopAudio();
    });

    // Обработка ошибок
    audioElement.onerror = function() {
      console.log("Ошибка загрузки аудиофайла!");
      // Восстанавливаем кнопку Play при ошибке
      $(".stopbgmusic").fadeOut(fadeTime);
      $(".playbgmusic").fadeIn(fadeTime);
    };
  });
